<Window x:Class="LibraryManagement.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление библиотекой" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="AddBookButton" Content="Добавить книгу" Width="120" Height="30" 
                    Margin="5" Click="AddBookButton_Click"/>
            <Button x:Name="EditBookButton" Content="Редактировать" Width="120" Height="30" 
                    Margin="5" Click="EditBookButton_Click"/>
            <Button x:Name="DeleteBookButton" Content="Удалить" Width="100" Height="30" 
                    Margin="5" Click="DeleteBookButton_Click"/>
            <Button x:Name="ManageAuthorsButton" Content="Авторы" Width="100" Height="30" 
                    Margin="5" Click="ManageAuthorsButton_Click"/>
            <Button x:Name="ManageGenresButton" Content="Жанры" Width="100" Height="30" 
                    Margin="5" Click="ManageGenresButton_Click"/>
            <Button x:Name="RefreshButton" Content="Обновить" Width="100" Height="30" 
                    Margin="5" Click="RefreshButton_Click"/>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" 
                CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Поиск:" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="SearchTextBox" Grid.Column="1" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Height="25" Margin="5"/>

                <TextBlock Grid.Column="2" Text="Автор:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox x:Name="AuthorFilterComboBox" Grid.Column="3" 
                          ItemsSource="{Binding Authors}" 
                          SelectedItem="{Binding SelectedAuthor}"
                          DisplayMemberPath="FullName" Height="25" Margin="5"/>

                <TextBlock Grid.Column="4" Text="Жанр:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox x:Name="GenreFilterComboBox" Grid.Column="5" 
                          ItemsSource="{Binding Genres}"
                          SelectedItem="{Binding SelectedGenre}"
                          DisplayMemberPath="Name" Height="25" Margin="5"/>
            </Grid>
        </Border>

        <DataGrid x:Name="BooksDataGrid" Grid.Row="2" 
                  ItemsSource="{Binding Books}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="200"/>
                <DataGridTextColumn Header="Автор" Binding="{Binding Author.FullName}" Width="150"/>
                <DataGridTextColumn Header="Жанр" Binding="{Binding Genre.Name}" Width="100"/>
                <DataGridTextColumn Header="Год" Binding="{Binding PublishYear}" Width="70"/>
                <DataGridTextColumn Header="ISBN" Binding="{Binding ISBN}" Width="120"/>
                <DataGridTextColumn Header="В наличии" Binding="{Binding QuantityInStock}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock x:Name="StatusTextBlock"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>