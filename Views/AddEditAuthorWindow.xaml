<Window x:Class="LibraryManagement.Views.AddEditAuthorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление/Редактирование автора" Height="300" Width="400"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Имя:" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="FirstNameTextBox" Grid.Row="0" Grid.Column="1" Margin="5" Height="25"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Фамилия:" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="LastNameTextBox" Grid.Row="1" Grid.Column="1" Margin="5" Height="25"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Дата рождения:" Margin="5" VerticalAlignment="Center"/>
        <DatePicker x:Name="BirthDatePicker" Grid.Row="2" Grid.Column="1" Margin="5" Height="25"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Страна:" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="CountryTextBox" Grid.Row="3" Grid.Column="1" Margin="5" Height="25"/>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="5">
            <Button x:Name="SaveButton" Content="Сохранить" Width="80" Height="30" 
                    Margin="5" Click="SaveButton_Click"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="80" Height="30" 
                    Margin="5" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>